{
	"files": [],
	"references": [
		{
			"path": "./tsconfig.app.json"
		},
		{
			"path": "./tsconfig.node.json"
		}
	],
	"compilerOptions": {
		"baseUrl": "./", // 基准路径通常设置为项目根目录 // 解析非相对模块的基地址，默认是当前目录
		"paths": {
			// 配置路径映射 //路径映射，相对于baseUrl
			// 告诉 TS/IDE：当看到 "@/*" 时，去 "src/*" 里面找
			"@/*": ["src/*"]
		}
	}
}
